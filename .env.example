APP_NAME=SIPANDA
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://127.0.0.1:8000

# Wajib diisi manual sebelum running/seeding di environment baru
ADMIN_DEFAULT_PASSWORD=

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# DB CONFIGURATION
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=sipanda
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=cookie
SESSION_LIFETIME=120

FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync
CACHE_STORE=file

